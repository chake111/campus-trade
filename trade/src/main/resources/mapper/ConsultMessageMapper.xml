<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.trade.mapper.ConsultMessageMapper">

    <resultMap id="ConsultMessageResultMap" type="com.campus.trade.entity.ConsultMessage">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="sender_id" property="senderId"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.campus.trade.entity.ConsultMessage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO consult_message (session_id, sender_id, content, create_time)
        VALUES (
            #{sessionId},
            #{senderId},
            #{content},
            IFNULL(#{createTime}, CURRENT_TIMESTAMP)
        )
    </insert>

    <select id="selectBySessionId" resultMap="ConsultMessageResultMap">
        SELECT id, session_id, sender_id, content, create_time
        FROM consult_message
        WHERE session_id = #{sessionId}
        ORDER BY create_time ASC, id ASC
    </select>

</mapper>
