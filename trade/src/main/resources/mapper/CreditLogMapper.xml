<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.trade.mapper.CreditLogMapper">

    <resultMap id="CreditLogResultMap" type="com.campus.trade.entity.CreditLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="change_value" property="changeValue"/>
        <result column="reason" property="reason"/>
        <result column="order_id" property="orderId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.campus.trade.entity.CreditLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO credit_log(user_id, change_value, reason, order_id, create_time)
        VALUES(
            #{userId},
            #{changeValue},
            #{reason},
            #{orderId},
            IFNULL(#{createTime}, CURRENT_TIMESTAMP)
        )
    </insert>

    <select id="selectByUserId" resultMap="CreditLogResultMap" parameterType="long">
        SELECT id, user_id, change_value, reason, order_id, create_time
        FROM credit_log
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

</mapper>
